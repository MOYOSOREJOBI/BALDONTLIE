# BALDONTLIE environment template
#
# Keep this file aligned with real code usage.
# Do not add placeholder secrets unless the code actually uses them.

# Optional for local app boot. Defaults to 5000 if omitted.
PORT=5000

# Optional for most frontend-only work. Required for DB-backed work such as:
# - `npm run db:push`
# - real persistence wiring
# - Drizzle/Supabase-backed development
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/baldontlie

# Optional legacy variables used only by the Vite meta-image plugin when running
# in Replit-style environments. Leave blank for normal local development.
REPLIT_INTERNAL_APP_DOMAIN=
REPLIT_DEV_DOMAIN=
